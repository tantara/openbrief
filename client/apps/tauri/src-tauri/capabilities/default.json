{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "transcript-overlay"],
  "permissions": [
    "core:default",
    "cli:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "log:default",
    "opener:default",
    "os:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install"
  ]
}
